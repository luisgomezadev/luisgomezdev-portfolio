---
import CvIcon from '../assets/icons/CvIcon.astro'
import EmailIcon from '../assets/icons/EmailIcon.astro'

import ButtonLink from './shared/ButtonLink.astro'

const { id } = Astro.props
---

<section
  id={id}
  class="relative min-h-screen scroll-mt-16 overflow-x-hidden bg-[#12161C] flex items-center"
>
  <div
    class="relative z-10 max-w-6xl mx-auto px-4 lg:px-6 py-24 flex flex-col-reverse md:flex-row items-center justify-between gap-12 w-full"
  >
    <div class="max-w-xl text-center md:text-left animate-fade-in-left">
      <p class="font-mono text-sm text-[#1FA98C] mb-3 tracking-tight">Luis Alberto Gómez Arteaga</p>

      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl leading-[1.1] text-[#F5F3EE]">
        Desarrollador de
        <span class="block italic text-[#1FA98C]">software</span>
      </h1>

      <p class="mt-6 text-lg text-[#8B96A8] max-w-md mx-auto md:mx-0">
        Construyo aplicaciones web escalables con Java, Spring Boot y Angular, cuidando tanto el
        rendimiento del backend como la experiencia de quien usa la interfaz.
      </p>

      <p class="font-mono text-sm text-[#8B96A8] mt-5 tracking-tight">
        java · spring boot · angular <span class="text-[#F2A93C]">// +5 años</span>
      </p>

      <footer class="flex gap-3 mt-8 justify-center md:justify-start">
        <ButtonLink
          title="Descargar CV de Luis Gomez"
          class="bg-[#1FA98C] text-[#12161C] font-semibold hover:bg-[#1FA98C]/90"
          href="/files/CV_Luis_Gomez_2026.pdf"
        >
          <CvIcon size={20} />
          Descargar mi CV
        </ButtonLink>
        <ButtonLink
          href="mailto:luisgomez24g@gmail.com"
          title="Enviar correo a Luis Gomez"
          class="border border-[#8B96A8]/40 text-[#F5F3EE] bg-transparent hover:border-[#1FA98C] hover:text-[#1FA98C]"
        >
          <EmailIcon size={20} />
          Contactar
        </ButtonLink>
      </footer>
    </div>

    <div class="relative animate-fade-in-up group">
      <span
        class="absolute -top-3 -left-3 w-10 h-10 border-t-2 border-l-2 border-[#1FA98C] transition-all duration-300 group-hover:-top-4 group-hover:-left-4"
      ></span>
      <span
        class="absolute -bottom-3 -right-3 w-10 h-10 border-b-2 border-r-2 border-[#1FA98C] transition-all duration-300 group-hover:-bottom-4 group-hover:-right-4"
      ></span>
      <img
        src="/images/perfil_linkedin.webp"
        alt="Luis Alberto Gómez Perfil"
        class="w-72 h-72 sm:w-80 sm:h-80 lg:w-96 lg:h-96 object-cover md:grayscale hover:grayscale-0 transition-all duration-500"
      />
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,600;1,500&family=JetBrains+Mono:wght@400;500&display=swap');

  .font-serif {
    font-family: 'Fraunces', serif;
  }
  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .animate-fade-in-left {
    animation: fadeInLeft 1s ease-out both;
  }
  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out both;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-left,
    .animate-fade-in-up,
    .cursor-blink {
      animation: none;
    }
  }
</style>
