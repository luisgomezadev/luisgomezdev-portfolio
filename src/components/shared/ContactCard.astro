---
const { href, title } = Astro.props
---

<article class="group relative">
  <span class="absolute top-0 left-0 w-4 h-4 border-t border-l border-[#8B96A8]/30 transition-all duration-300 group-hover:border-[#1FA98C] group-hover:-translate-x-1 group-hover:-translate-y-1" />
  <span class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-[#8B96A8]/30 transition-all duration-300 group-hover:border-[#1FA98C] group-hover:translate-x-1 group-hover:translate-y-1" />

  <a
    class="flex gap-5 items-center px-6 py-6 transition-colors duration-300"
    href={href}
    target="_blank"
    rel="noopener noreferrer"
  >
    <picture class="text-[#8B96A8] group-hover:text-[#1FA98C] transition-colors duration-300">
      <slot name="icon" />
    </picture>
    <div>
      <h1 class="font-serif text-xl text-[#F5F3EE] mb-1">
        {title}
      </h1>
      <slot name="description" />
    </div>
  </a>
</article>

<style>
  .font-serif { font-family: 'Fraunces', serif; }
</style>