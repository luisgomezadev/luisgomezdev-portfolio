---
import Section from './shared/Section.astro'
import ButtonLink from './shared/ButtonLink.astro'
import GitHub from '../assets/icons/GitHub.astro'
import WebIcon from '../assets/icons/WebIcon.astro'

import { PROJECTS } from '../data/projects'

const { id } = Astro.props
---

<Section
  title="Proyectos"
  id={id}
  subtitle="Algunos de los proyectos que he desarrollado"
  class="bg-[#12161C]"
  dark={true}
>
  <div class="lg:py-8 px-4 lg:px-6 max-w-5xl mx-auto flex flex-col gap-16 md:gap-20">
    {
      PROJECTS.map(
        (project, i) =>
          project.home && (
            <article
              class="flex flex-col md:flex-row gap-8 md:gap-12 items-center"
              data-aos="fade-up"
            >
              <div class={`w-full md:w-1/2 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
                <div class="group relative overflow-hidden">
                  <span class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-[#1FA98C] z-10 transition-all duration-300 group-hover:-translate-x-1 group-hover:-translate-y-1" />
                  <span class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-[#1FA98C] z-10 transition-all duration-300 group-hover:translate-x-1 group-hover:translate-y-1" />
                  <img
                    class="w-full object-cover md:grayscale group-hover:grayscale-0 transition-all duration-500"
                    src={project.image}
                    alt={project.title}
                    loading="lazy"
                  />
                </div>
              </div>

              <div class={`w-full md:w-1/2 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
                <h1 class="font-serif text-2xl md:text-3xl text-[#F5F3EE] mb-4">
                  {project.title}
                </h1>

                <p class="text-base text-[#8B96A8] leading-relaxed mb-5">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-x-4 gap-y-2 mb-6">
                  {project.technologies.map((tech) => (
                    <span class="font-mono text-xs text-[#8B96A8] flex items-center gap-1.5">
                      <img src={tech.image} class="w-3.5 h-3.5 object-contain" alt="" />
                      {tech.name}
                    </span>
                  ))}
                </div>

                <div class="flex items-center gap-4">
                  {project.live && (
                    <ButtonLink
                      href={project.live}
                      title={`Ver demo de proyecto ${project.title}`}
                      class="bg-[#1FA98C] text-[#12161C] font-semibold hover:bg-[#1FA98C]/90"
                    >
                      <WebIcon size={20} />
                      Ver demo
                    </ButtonLink>
                  )}
                  {project.link && (
                    <ButtonLink
                      title={`Ver repositorio de proyecto ${project.title}`}
                      class="border border-[#8B96A8]/40 text-[#F5F3EE] bg-transparent hover:border-[#1FA98C] hover:text-[#1FA98C]"
                      href={project.link}
                    >
                      <GitHub size={20} />
                      Ver código
                    </ButtonLink>
                  )}
                </div>
              </div>
            </article>
          )
      )
    }
  </div>
</Section>

<style>
  .font-serif { font-family: 'Fraunces', serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }
</style>